                ]
            },
            {
                "stanza_number": 2,
                "lines": [
                    "ಇತಿಹಾಸದ ಹಿಮದಲ್ಲಿನ ಸಿಂಹಾಸನ ಮೂಲೆಯಲ್ಲಿ",
                    "ಗತ ಸಾಹಸ ಸಾರುತಿರುವ ಶಾಸನಗಳ ಸಾಲಿನಲ್ಲಿ",
