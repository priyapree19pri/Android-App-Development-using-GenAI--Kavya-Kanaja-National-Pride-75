        "title": "ಎಲ್ಲಾದರು ಇರು ಎಂತಾದರು ಇರು",
        "author": "ಕುವೆಂಪು",
        "type": "ನಾಡಪ್ರೇಮದ ಗೀತೆ",
        "lyrics": [
            {
                "stanza": 1,
                "lines": [
                    "ಎಲ್ಲಾದರು ಇರು ಎಂತಾದರು ಇರು",
                    "ಎಂದೆಂದಿಗೂ ನೀ ಕನ್ನಡವಾಗಿರು",
