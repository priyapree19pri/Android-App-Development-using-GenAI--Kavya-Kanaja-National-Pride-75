                ]
            },
            {
                "stanza_number": 3,
                "lines": [
                    "ಹಲವೆನ್ನದ ಹಿರಿಮೆಯೆ, ಕುಲವೆನ್ನದ ಗರಿಮೆಯೆ",
                    "ಸದ್ವಿಕಾಸಶೀಲ ನುಡಿಯ ಲೋಕಾವೃತ ಸೀಮೆಯೆ",
                    "ಈ ವತ್ಸರ ನಿರ್ಮತ್ಸರ ಮನದುದಾರ ಮಹಿಮೆಯೆ",
                    "ನಿತ್ಯೋತ್ಸವ ತಾಯಿ ನಿತ್ಯೋತ್ಸವ",
                    "ನಿನಗೆ ನಿತ್ಯೋತ್ಸವ ತಾಯಿ ನಿತ್ಯೋತ್ಸವ"
                ]
            }
