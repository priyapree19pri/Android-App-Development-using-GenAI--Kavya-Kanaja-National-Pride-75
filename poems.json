[
    {
        "id_poem": 1,
        "title": "ಜಯ ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ",
        "author": "ಕುವೆಂಪು",
        "type": "ನಾಡಗೀತೆ / ರಾಷ್ಟ್ರಭಕ್ತಿಗೀತೆ",
        "lyrics": [
            {
                "stanza": 1,
                "lines": [
                    "ಜಯ ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ, ಜಯ ಹೇ ಕರ್ನಾಟಕ ಮಾತೆ.",
                    "ಜಯ ಸುಂದರ ನದಿ ವನಗಳ ನಾಡೇ, ಜಯ ಹೇ ರಸಋಷಿಗಳ ಬೀಡೆ."
                ]
            },
            {
                "stanza": 2,
                "lines": [
                    "ಭೂದೇವಿಯ ಮಕುಟದ ನವಮಣಿಯೆ, ಗಂಧದ ಚಂದದ ಹೊನ್ನಿನ ಗಣಿಯೆ.",
                    "ರಾಘವ ಮಧುಸೂಧನರವತರಿಸಿದ ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ, ಜಯ ಹೇ ಕರ್ನಾಟಕ ಮಾತೆ."
                ]
            },
            {
                "stanza": 3,
                "lines": [
                    "ಜನನಿಯ ಜೋಗುಳ ವೇದದ ಘೋಷ, ಜನನಿಗೆ ಜೀವವು ನಿನ್ನಾವೇಶ.",
                    "ಹಸುರಿನ ಗಿರಿಗಳ ಸಾಲೇ, ನಿನ್ನಯ ಕೊರಳಿನ ಮಾಲೆ.",
                    "ಕಪಿಲ ಪತಂಜಲ ಗೌತಮ ಜಿನನುತ ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ, ಜಯ ಹೇ ಕರ್ನಾಟಕ ಮಾತೆ."
                ]
            },
            {
                "stanza": 4,
                "lines": [
                    "ಶಂಕರ ರಾಮಾನುಜ ವಿದ್ಯಾರಣ್ಯ, ಬಸವೇಶ್ವರ ಮಧ್ವರ ದಿವ್ಯಾರಣ್ಯ.",
                    "ರನ್ನ ಷಡಕ್ಷರಿ ಪೊನ್ನ, ಪಂಪ ಲಕುಮಿಪತಿ ಜನ್ನ.",
                    "ಕುಮಾರವ್ಯಾಸರ ಮಂಗಳಧಾಮ, ಕವಿಕೋಗಿಲೆಗಳ ಪುಣ್ಯಾರಾಮ.",
                    "ನಾನಕ ರಮಾನಂದ ಕಬೀರರ ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ, ಜಯ ಹೇ ಕರ್ನಾಟಕ ಮಾತೆ."
                ]
            },
            {
                "stanza": 5,
                "lines": [
                    "ತೈಲಪ ಹೊಯ್ಸಳರಾಳಿದ ನಾಡೆ, ಡಂಕಣ ಜಕಣರ ನೆಚ್ಚಿನ ಬೀಡೆ.",
                    "ಕೃಷ್ಣ ಶರಾವತಿ ತುಂಗಾ, ಕಾವೇರಿಯ ವರ ರಂಗ.",
                    "ಚೈತನ್ಯ ಪರಮಹಂಸ ವಿವೇಕರ ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ, ಜಯ ಹೇ ಕರ್ನಾಟಕ ಮಾತೆ."
                ]
            },
            {
                "stanza": 6,
                "lines": [
                    "ಸರ್ವಜನಾಂಗದ ಶಾಂತಿಯ ತೋಟ, ರಸಿಕರ ಕಂಗಳ ಸೆಳೆಯುವ ನೋಟ.",
                    "ಹಿಂದೂ ಕ್ರೈಸ್ತ ಮುಸಲ್ಮಾನ, ಪಾರಸಿಕ ಜೈನರುದ್ಯಾನ.",
                    "ಜನಕನ ಹೋಲುವ ದೊರೆಗಳ ಧಾಮ, ಗಾಯಕ ವೈಣಿಕರಾರಾಮ."
                ]
            },
            {
                "stanza": 7,
                "lines": [
                    "ಕನ್ನಡ ನುಡಿ ಕುಣಿದಾಡುವ ಗೇಹ, ಕನ್ನಡ ತಾಯಿಯ ಮಕ್ಕಳ ದೇಹ.",
                    "ಭಾರತ ಜನನಿಯ ತನುಜಾತೆ, ಜಯ ಹೇ ಕರ್ನಾಟಕ ಮಾತೆ.",
                    "ಜಯ ಸುಂದರ ನದಿ ವನಗಳ ನಾಡೆ, ಜಯ ಹೇ ರಸಋಷಿಗಳ ಬೀಡೆ."
                ]
            }
        ],
        "audioURL": "poet1.mp3"
