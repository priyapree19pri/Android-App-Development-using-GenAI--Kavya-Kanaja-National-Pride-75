    {
        "id_poem": 2,
        "title": "ನಿತ್ಯೋತ್ಸವ",
        "author": " ಕೆ. ಎಸ್. ನಿಸಾರ್ ಅಹಮದ್",
        "type": "ಕವಿತೆ / ನಾಡು ನುಡಿಯ ಗೀತೆ",
        "lyrics": [
            {
                "stanza_number": 1,
                "lines": [
                    "ಜೋಗದ ಸಿರಿ ಬೆಳಕಿನಲ್ಲಿ, ತುಂಗೆಯ ತೆನೆ ಬಳುಕಿನಲ್ಲಿ",
                    "ಸಹ್ಯಾದ್ರಿಯ ಲೋಹದದಿರ ಉತ್ತುಂಗದ ನಿಲುಕಿನಲ್ಲಿ",
                    "ನಿತ್ಯಹರಿದ್ವರ್ಣವನದ ತೇಗ ಗಂಧ ತರುಗಳಲ್ಲಿ",
                    "ನಿತ್ಯೋತ್ಸವ ತಾಯಿ ನಿತ್ಯೋತ್ಸವ",
